{
  "name": "@thejokersthief/riftbound-test-helpers",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint ./src",
    "format": "biome format --check ./src",
    "test": "vitest run"
  },
  "dependencies": {
    "@thejokersthief/riftbound-engine": "workspace:*",
    "@thejokersthief/riftbound-card-catalog": "workspace:*",
    "@thejokersthief/riftbound-protocol": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "*",
    "oxlint": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
